# ===================================
# ENVIRONMENT VARIABLES
# Copy file ini sebagai .env dan sesuaikan dengan konfigurasi lokal Anda
# ===================================

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=anime_recommender

# Optional: Jika menggunakan remote database
# DB_HOST=your-remote-server.com
# DB_USER=your_username
# DB_PASSWORD=your_password

# Application Settings
STREAMLIT_THEME_BASE=dark
STREAMLIT_THEME_PRIMARY_COLOR=#ff006e
STREAMLIT_THEME_BACKGROUND_COLOR=#0a0e27
STREAMLIT_THEME_SECONDARY_BACKGROUND_COLOR=#1a1f3a
STREAMLIT_THEME_TEXT_COLOR=#e0e0e0

# Debug Mode
DEBUG=False
LOG_LEVEL=INFO
